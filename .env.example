# Optional deployment environment variables
JAWDAH_HOST=0.0.0.0
# Most cloud platforms provide PORT automatically. Locally you may use:
JAWDAH_PORT=8765
# Use a persistent disk path in production, for example /var/data
JAWDAH_DATA_DIR=./data
# Optional direct database path
# JAWDAH_DB_PATH=./data/jawdah.sqlite3
