# Railway / production
JAWDAH_HOST=0.0.0.0
# Railway sets PORT automatically
JAWDAH_DATA_DIR=/app/data
# JAWDAH_DB_PATH=/app/data/jawdah.sqlite3
# JAWDAH_COMPANY_SETTINGS=/app/data/company_settings.json
# JAWDAH_CORS_ORIGIN=*

# Security (required for admin login)
ADMIN_PASSWORD=your-secure-admin-password

# Security (optional)
# JAWDAH_DEBUG=0
# JAWDAH_HSTS=1
# JAWDAH_MAX_JSON_BYTES=1048576
# JAWDAH_LOGIN_RATE_LIMIT=8
# JAWDAH_LOGIN_WINDOW_SEC=300
# JAWDAH_SESSION_HOURS=12

# One-time wipe of all business data on startup (remove after first deploy)
# JAWDAH_FRESH_START=1

# JAWDAH_BACKUP_HOUR=3
# JAWDAH_BACKUP_RETAIN_DAYS=14
# JAWDAH_BACKUP_TZ=Asia/Muscat
# JAWDAH_AUTO_BACKUP=1

# Local development
# JAWDAH_PORT=8765
# JAWDAH_DATA_DIR=./data
